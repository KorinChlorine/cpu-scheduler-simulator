<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cpusched.ResultController"
      stylesheets="@primary.css">

    <VBox spacing="0">

        <!-- Header Bar -->
        <HBox styleClass="header-bar" alignment="CENTER_LEFT">
            <Button text="Back" onAction="#onBack" styleClass="btn-back"/>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <padding><Insets left="15"/></padding>
                <Label fx:id="algorithmLabel" text="SIMULATION RESULTS" styleClass="header-title"/>
                <Label fx:id="formulaLegend" text="" styleClass="header-subtitle"/>
            </VBox>
        </HBox>
        <Separator styleClass="header-separator"/>

        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="14" styleClass="result-scroll-content">

                <!-- ── SINGLE MODE: Gantt── -->
                <HBox fx:id="singleModeTop" spacing="14" alignment="CENTER">

                    <!-- Gantt Chart Cell -->
                    <VBox styleClass="bento-cell bento-cell-gantt" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="GANTT CHART" styleClass="bento-cell-label" textFill="#3d1f0a"/>
                        <ScrollPane fitToHeight="true" prefHeight="110" minHeight="90"
                                    styleClass="scroll-pane" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED">
                            <VBox fx:id="ganttContainer" spacing="4" style="-fx-padding: 4;"/>
                        </ScrollPane>
                    </VBox>
                </HBox>

                <!-- ── SINGLE MODE: Avg WT + Avg TAT bento cells ── -->
                <HBox fx:id="singleModeStats" spacing="14">
                    <VBox styleClass="bento-cell stat-card stat-card-wt" spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label text="AVG WAITING TIME"    styleClass="stat-label"/>
                        <Label fx:id="avgWTLabel"  text="0.00" styleClass="stat-value-wt"/>
                        <Label text="time units" styleClass="stat-unit"/>
                    </VBox>
                    <VBox styleClass="bento-cell stat-card stat-card-tat" spacing="6" alignment="CENTER" HBox.hgrow="ALWAYS">
                        <Label text="AVG TURNAROUND TIME" styleClass="stat-label"/>
                        <Label fx:id="avgTATLabel" text="0.00" styleClass="stat-value-tat"/>
                        <Label text="time units" styleClass="stat-unit"/>
                    </VBox>
                </HBox>

                <!-- ── SINGLE MODE: Metrics Table ── -->
                <VBox fx:id="singleModeTable" styleClass="bento-cell" spacing="8">
                    <Label text="PROCESS METRICS" styleClass="bento-cell-label" textFill="#3d1f0a"/>
                    <TableView fx:id="metricsTable" prefHeight="220" minHeight="160" styleClass="table-view">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="mColId"  text="Process"    minWidth="50"/>
                            <TableColumn fx:id="mColAT"  text="Arrival"    minWidth="55"/>
                            <TableColumn fx:id="mColBT"  text="Burst"      minWidth="55"/>
                            <TableColumn fx:id="mColCT"  text="Completion" minWidth="70"/>
                            <TableColumn fx:id="mColWT"  text="Wait"       minWidth="55"/>
                            <TableColumn fx:id="mColTAT" text="Turnaround" minWidth="70"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- ── SINGLE MODE: Computation Breakdown ── -->
                <VBox fx:id="singleModeFormula" styleClass="bento-cell" spacing="8">
                    <Label text="COMPUTATION BREAKDOWN" styleClass="bento-cell-label" textFill="#3d1f0a"/>
                    <TextArea fx:id="formulaArea" styleClass="formula-area" editable="false" prefHeight="260"/>
                </VBox>

                <!-- ── COMPARE MODE: Grid of algorithm cards ── -->
                <VBox fx:id="comparePanel" spacing="12" visible="false" managed="false">
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>